<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".SplashActivity">
    <ImageView
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@drawable/logoderana"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="150dp"
        android:id="@+id/logokemendikbud"
        android:background="@drawable/background_logo"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Derana"
        android:id="@+id/textlabor"
        android:fontFamily="@font/jakartabold"
        android:layout_marginTop="30dp"
        android:textSize="18dp"
        android:layout_centerHorizontal="true"
        android:layout_below="@id/logokemendikbud"/>


    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="100dp"
        android:layout_below="@id/textlabor"
        android:background="@drawable/progres_loading"
        android:progressTint="@color/biru"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kantor Bahasa Provinsi Maluku"
        android:id="@+id/textBottomKantor"
        android:layout_below="@id/progressBar"
        android:layout_centerHorizontal="true"
        android:fontFamily="@font/jakartabold"
        android:textSize="14dp"
        android:layout_marginTop="160dp"/>
        <TextView
            android:layout_width="240dp"
            android:textAlignment="center"
            android:layout_height="wrap_content"
            android:text="Kementerian Pendidikan, Kebudayaan, Riset, dan Teknologi"
            android:layout_below="@id/textBottomKantor"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="10dp"/>



</RelativeLayout>