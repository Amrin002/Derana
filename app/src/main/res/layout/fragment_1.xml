<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".fragment.Fragment1"
    android:layout_marginTop="30dp">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

    <!-- TODO: Update blank fragment layout -->

    <ImageView
        android:id="@+id/image_view"
        android:layout_width="230dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_young"

        android:src="@drawable/young_man_surrounded_by_gadgets_taking_notes"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="10dp"/>
        <TextView
            android:textColor="@color/white"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selamat datang di Derana"
            android:fontFamily="@font/jakartabold"
            android:textSize="18sp"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="250dp"
            android:id="@+id/selamat"
            />

        <TextView
            android:textColor="@color/white"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aplikasi ini dapat memudahkan untuk \nmengetahui seluk-beluk tentang bahasa dan \nsastra di Provinsi Maluku."
            android:textSize="13sp"
            android:fontFamily="@font/jakartareguler"
            android:textAlignment="center"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="320dp"/>
    </RelativeLayout>
</FrameLayout>