<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"

    tools:context=".VerificationActivity"
    android:background="@color/white">
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">
    <include layout="@layout/_ly_verification_header_logo" />


    <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="20dp">
        <TextView
            android:textColor="@color/black"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kode OTP sudah dikirim!"
            android:fontFamily="@font/jakartabold"
            android:textSize="20dp"/>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textColor="@color/black"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Masukkan kode OTP yang kami kirim \nmelalui nomor: "
                android:textSize="14.5dp"
                android:fontFamily="@font/jakartareguler"
                android:layout_marginTop="20dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_marginStart="108dp"
                android:id="@+id/emailVerification"
                android:layout_marginTop="38dp"
                android:fontFamily="@font/jakartabold"
                android:text="email@gmail.com"
                android:textColor="@color/black"
                android:textSize="14.5dp" />

        </RelativeLayout>




    </LinearLayout>


    <RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="40dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:id="@+id/ly">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kode OTP"
                android:textColor="@color/black"
                android:fontFamily="@font/jakartabold"
                android:textSize="16dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="*"
                android:textColor="@color/merah"
                android:textStyle="bold"
                android:textSize="16dp"
                android:layout_marginLeft="3dp"/>
        </LinearLayout>
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="6"
            android:rowCount="1"
            android:layout_below="@id/ly"
            android:layout_marginTop="10dp">
            <!-- First digit -->
            <EditText
                android:id="@+id/etOtp1"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:textColor="@color/black"
                android:inputType="number"
                android:maxLength="1"
                android:textAlignment="center"
                android:background="@drawable/edit_text_border"
                android:layout_marginRight="8dp"/>

            <!-- Second digit -->
            <EditText
                android:id="@+id/etOtp2"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:inputType="number"
                android:textColor="@color/black"
                android:maxLength="1"
                android:textAlignment="center"
                android:background="@drawable/edit_text_border"
                android:layout_marginRight="8dp"/>

            <!-- Third digit -->
            <EditText
                android:id="@+id/etOtp3"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:textColor="@color/black"
                android:inputType="number"
                android:maxLength="1"
                android:textAlignment="center"
                android:background="@drawable/edit_text_border"
                android:layout_marginRight="8dp"/>

            <!-- Fourth digit -->
            <EditText
                android:id="@+id/etOtp4"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:inputType="number"
                android:maxLength="1"
                android:textColor="@color/black"
                android:textAlignment="center"
                android:background="@drawable/edit_text_border"
                android:layout_marginRight="8dp"/>

            <!-- Fifth digit -->
            <EditText
                android:id="@+id/etOtp5"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:inputType="number"
                android:textColor="@color/black"
                android:maxLength="1"
                android:textAlignment="center"
                android:background="@drawable/edit_text_border"
                android:layout_marginRight="8dp"/>

            <!-- Sixth digit -->
            <EditText
                android:id="@+id/etOtp6"
                android:layout_width="40dp"
                android:textColor="@color/black"
                android:layout_height="40dp"
                android:inputType="number"
                android:maxLength="1"
                android:textAlignment="center"
                android:background="@drawable/edit_text_border"/>
        </GridLayout>

    </RelativeLayout>


</LinearLayout>
    <Button
        android:layout_above="@id/linearlayoutKebijakan3"
        android:layout_marginBottom="@dimen/dim_20"
        android:background="@drawable/buttonmasuk2"
        android:layout_width="300dp"
        android:layout_height="50dp"
        android:text="Lanjutkan"
        android:layout_centerHorizontal="true"
        android:id="@+id/btnLanjut"
        android:elegantTextHeight="true"
        android:textAllCaps="false"
        android:textSize="16dp"
        android:textColor="@color/white"
        android:fontFamily="@font/jakartabold"/>

    <LinearLayout
        android:id="@+id/linearlayoutKebijakan3"
        android:layout_width="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dim_15"
        android:layout_centerHorizontal="true"
        >
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/black"
            android:text="Dengan masuk atau mendaftar, kamu menyetujui"
            android:fontFamily="@font/jakartalight"
            android:textSize="13.1sp"/>
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="-5dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Terms of Service"
                android:textColor="@color/black"

                android:fontFamily="@font/jakartabolditalic"
                android:id="@+id/btnTerms"
                android:onClick="layanan"/>
            <TextView
                android:textColor="@color/black"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="dan"
                android:fontFamily="@font/jakartareguler"
                android:paddingLeft="3dp"
                android:paddingRight="3dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/btnPrivaci"
                android:text="Privacy Policy"
                android:textColor="@color/black"
                android:fontFamily="@font/jakartabolditalic"
                android:onClick="privasi"
                />

        </LinearLayout>


    </LinearLayout>
</RelativeLayout>