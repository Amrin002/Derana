<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".newchat.NewChatActivity"
    android:background="@color/white">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/chatBar">

        <ImageButton
            android:id="@+id/backChat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"
            android:layout_centerVertical="true"
            android:layout_marginStart="14dp"
            android:layout_marginTop="16dp"
            android:background="@color/transparansi"

            android:src="@drawable/icons_arrow_left" />

        <TextView
            android:id="@+id/iconprofilNewChat"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/profilchat"
            android:text="K"
            android:textAlignment="center"
            android:elegantTextHeight="true"
            android:textColor="@color/white"
            android:textColorHint="@color/white"
            android:fontFamily="@font/jakartabold"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_toEndOf="@id/backChat"
            android:layout_alignParentTop="true"
            android:layout_marginTop="@dimen/dim_5"
            android:layout_marginStart="@dimen/dim_15"
            />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/kontakChat"
            android:layout_toEndOf="@id/iconprofilNewChat"
            android:text="Konsultasi"
            android:textSize="16sp"
            android:textColor="@color/black"
            android:fontFamily="@font/jakartabold"
            android:layout_marginStart="@dimen/dim_10"
            />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/profilStatus"
            android:textSize="14sp"
            android:text="Layanan Informasi dan Pengaduan"
            android:layout_toEndOf="@id/iconprofilNewChat"
            android:layout_below="@id/kontakChat"
            android:fontFamily="@font/jakartareguler"
            android:textColor="@color/black"
            android:layout_marginStart="@dimen/dim_10"/>

    </RelativeLayout>
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bgchating"
        android:id="@+id/popUpChat"
        android:layout_below="@id/chatBar">
        <!--        pop up chat disini-->
    </RelativeLayout>
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/chatBarBottom"
        android:layout_below="@id/popUpChat"
        android:layout_alignParentBottom="true">
        <ImageButton
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/addProperty"
            android:src="@drawable/buttonaddchat1"
            android:background="@color/transparansi"
            android:layout_centerVertical="true"
            />
        <ImageButton
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/addImage"
            android:layout_toEndOf="@id/addProperty"
            android:layout_centerVertical="true"
            android:src="@drawable/buttonaddimage"
            android:background="@color/transparansi"
            android:layout_marginStart="@dimen/dim_10"
            />
        <EditText
            android:layout_width="270dp"
            android:layout_height="50dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/etchat"
            android:layout_toEndOf="@id/addImage"
            android:layout_centerVertical="true"
            android:id="@+id/etNewChat"
            android:inputType="text"


            />
        <ImageButton
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_toEndOf="@id/etNewChat"
            android:id="@+id/btnSend"
            android:layout_alignParentEnd="true"
            android:src="@drawable/btnsend"
            android:background="@color/transparansi"
            android:layout_centerVertical="true"
            android:layout_marginEnd="10dp"
            android:layout_marginStart="10dp"/>




    </RelativeLayout>

</RelativeLayout>