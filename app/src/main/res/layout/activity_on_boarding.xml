<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"

    android:paddingHorizontal="@dimen/dim_10"

    tools:context=".OnBoardingActivity">

    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <include layout="@layout/_ly_onboarding_header_login" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_13">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="@dimen/dim_10"
                android:layout_marginBottom="@dimen/dim_20"
                android:orientation="horizontal">

                <ProgressBar

                    android:id="@+id/pb1"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="@dimen/dim_60"
                    android:layout_height="@dimen/dim_5"
                    android:layout_marginRight="@dimen/dim_20"
                    android:indeterminate="false"
                    android:indeterminateDrawable="@drawable/progress_indeterminate"
                    android:progressDrawable="@drawable/progress_horizontal" />

                <ProgressBar

                    android:id="@+id/pb2"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="@dimen/dim_60"
                    android:layout_height="@dimen/dim_5"
                    android:layout_marginRight="@dimen/dim_20"
                    android:indeterminate="false"
                    android:indeterminateDrawable="@drawable/progress_indeterminate"
                    android:progressDrawable="@drawable/progress_horizontal" />

                <ProgressBar

                    android:id="@+id/pb3"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="@dimen/dim_60"
                    android:layout_height="@dimen/dim_5"
                    android:layout_marginRight="@dimen/dim_20"
                    android:indeterminate="false"
                    android:indeterminateDrawable="@drawable/progress_indeterminate"
                    android:progressDrawable="@drawable/progress_horizontal" />

                <ProgressBar
                    android:id="@+id/pb4"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="@dimen/dim_60"
                    android:layout_height="@dimen/dim_5"
                    android:indeterminate="false"
                    android:indeterminateDrawable="@drawable/progress_indeterminate"

                    android:progressDrawable="@drawable/progress_horizontal" />
            </LinearLayout>
        </RelativeLayout>

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/viewPager2"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dim_400"
            android:layout_marginTop="@dimen/dim_30" />

        <include layout="@layout/_ly_onboard_masuk" />

        <include layout="@layout/_ly_onboarding_kebijakan" />

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>