<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_marginStart="10dp"
    >
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="25dp"
        android:orientation="horizontal"
        android:id="@+id/privation">
    <CheckBox
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/checkboxKebijakan"/>

        <TextView
            android:id="@+id/txt1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/jakartareguler"
            android:text="Saya telah membaca dan menerima segala isi"
            />
    </LinearLayout>
    <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
        android:layout_marginTop="-5dp"
        android:layout_below="@id/privation"
        android:layout_marginLeft="2dp"
        android:id="@+id/ly"
    >

        <TextView
            android:id="@+id/Syarat"
            android:layout_width="wrap_content"
            android:layout_height="26dp"
            android:layout_below="@id/txt1"

            android:layout_alignParentStart="true"
            android:layout_marginStart="30dp"

            android:layout_marginRight="228dp"
            android:fontFamily="@font/jakartabold"
            android:onClick="Syarat"
            android:text="Syarat Pengguna"
            android:textColor="#00A4DE" />

        <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/txt1"
        android:layout_marginLeft="3dp"
        android:layout_centerHorizontal="true"
        
        android:text="dan" />

    <TextView
        android:id="@+id/kebijakan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="3dp"
        android:fontFamily="@font/jakartabold"
        android:onClick="kebijakan"
        android:text="Kebijakan Privasi"
        android:textColor="#00A4DE" />
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Derana"
        android:layout_marginStart="3dp"
        android:fontFamily="@font/jakartareguler"/>
</LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="30dp"
        android:id="@+id/haveacount"
        android:layout_below="@id/ly">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/jakartareguler"
            android:text="Sudah punya akun Derana?"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:onClick="masuk"
            android:text="Masuk"
            android:id="@+id/haveAccount"
            android:fontFamily="@font/jakartabold"
            android:textColor="#00A4DE"
            android:layout_marginLeft="5dp"/>

    </LinearLayout>




</RelativeLayout>