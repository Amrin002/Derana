<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    tools:context=".fragment.Fragment2">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- TODO: Update blank fragment layout -->

        <ImageView
            android:id="@+id/image_view"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_girl"

            android:src="@drawable/girl_studying_with_book_and_laptop"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="10dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Temukan berbagai pengetahuan \ntentang bahasa dan sastra"
            android:fontFamily="@font/jakartabold"
            android:textSize="18sp"
            android:textAlignment="center"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="20dp"
            android:id="@+id/selamat"
            android:layout_below="@id/image_view"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dengan aplikasi ini, kamu dapat mengetahui \nberbagai khasanah bahasa dan sastra daerah \nyang terdapat di Provinsi Maluku."
            android:layout_below="@id/selamat"
            android:fontFamily="@font/jakartareguler"
            android:textAlignment="center"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="100dp"/>
    </RelativeLayout>
</FrameLayout>