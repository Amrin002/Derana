<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:orientation="vertical"
    android:layout_height="143dp"
    android:layout_marginBottom="10dp"
   android:paddingHorizontal="15dp">
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Berita kebahasaan hari ini"
        android:fontFamily="@font/jakartabold"
        android:textSize="16sp"
        android:textColor="@color/black"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">
<!--        nanti tambahkan tag html legacy di kotlinnya-->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Baca update berita terkait dengan kebahasaan "
            android:fontFamily="@font/jakartareguler"
            android:textColor="#999798"

            android:textSize="13sp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lihat Semua"
            android:fontFamily="@font/jakartabold"
            android:textColor="@color/primary"
            android:textSize="13sp"
            android:layout_marginRight="15dp"
            android:id="@+id/seeAll2"/>
    </LinearLayout>
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginTop="25dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button
                android:layout_width="110dp"
                android:layout_height="34dp"
                android:elegantTextHeight="true"
                android:textSize="13sp"
                android:text="Terbaru"
                android:textColor="@color/white"
                android:fontFamily="@font/jakartareguler"
                android:textAllCaps="false"
                android:background="@drawable/bg_button_ayobelajar"
                android:id="@+id/btnBerita1"
                android:layout_marginRight="10dp"/>
            <Button
                android:layout_width="110dp"
                android:layout_height="34dp"
                android:elegantTextHeight="true"
                android:textSize="13sp"
                android:text="Balai Bahasa"
                android:textColor="@color/black"
                android:fontFamily="@font/jakartareguler"
                android:textAllCaps="false"
                android:background="@drawable/bg_button_ayobelajar_notactivated"
                android:id="@+id/btnBerita2"
                android:layout_marginRight="10dp"/>
            <Button
                android:layout_width="110dp"
                android:layout_height="34dp"
                android:elegantTextHeight="true"
                android:textSize="13sp"
                android:text="Kantor Bahasa"
                android:textColor="@color/black"
                android:fontFamily="@font/jakartareguler"
                android:textAllCaps="false"
                android:background="@drawable/bg_button_ayobelajar_notactivated"
                android:id="@+id/btnBerita3"
                android:layout_marginRight="10dp"/>
            <Button
                android:layout_width="110dp"
                android:layout_height="34dp"
                android:elegantTextHeight="true"
                android:textSize="13sp"
                android:text="Badan Bahasa"
                android:textColor="@color/black"
                android:fontFamily="@font/jakartareguler"
                android:textAllCaps="false"
                android:background="@drawable/bg_button_ayobelajar_notactivated"
                android:id="@+id/btnBerita4"
                android:layout_marginRight="10dp"/>
            <Button
                android:layout_width="110dp"
                android:layout_height="34dp"
                android:elegantTextHeight="true"
                android:textSize="13sp"
                android:text="Merdeka Belajar"
                android:textColor="@color/black"
                android:fontFamily="@font/jakartareguler"
                android:textAllCaps="false"
                android:background="@drawable/bg_button_ayobelajar_notactivated"
                android:id="@+id/btnBerita5"
                android:layout_marginRight="10dp"/>

        </LinearLayout>
    </HorizontalScrollView>
</LinearLayout>