<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="@dimen/dim_20"
    tools:context=".fragmentberanda.LaporFragment"
    android:background="@color/white">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dim_20">

        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            >
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/img_lapordetail"
                android:id="@+id/lprKategori"
                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kategori"
                android:id="@+id/txlprKategori"
                android:fontFamily="@font/jakartabold"
                android:layout_below="@id/lprKategori"
                android:layout_marginTop="@dimen/dim_5"
                android:textColor="@color/black"/>
            <ProgressBar
                android:id="@+id/progressLapor1"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="90dp"
                android:layout_height="1dp"
                android:layout_toEndOf="@id/lprKategori"
                android:layout_marginTop="@dimen/dim_20"
                android:progress="100"
                android:progressDrawable="@drawable/progress_belajar" />
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_centerHorizontal="true"
                android:src="@drawable/img_lapordetail"
                android:layout_toEndOf="@id/progressLapor1"
                android:id="@+id/lprFoto"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Foto"
                android:layout_centerHorizontal="true"
                android:fontFamily="@font/jakartabold"
                android:textColor="@color/black"
                android:layout_below="@id/lprFoto"
                android:layout_marginTop="@dimen/dim_5"

                android:id="@+id/txlprFoto"/>
            <ProgressBar
                android:id="@+id/progressLapor2"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="@dimen/dim_90"
                android:layout_height="1dp"
                android:layout_toEndOf="@id/lprFoto"
                android:layout_marginTop="@dimen/dim_20"
                android:progressDrawable="@drawable/progress_belajar" />
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/img_lapordetail"
                android:layout_toEndOf="@id/progressLapor2"
                android:id="@+id/lprDetail"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Detail"

                android:fontFamily="@font/jakartabold"
                android:textColor="@color/black"
                android:layout_below="@id/lprDetail"
                android:layout_toEndOf="@id/txlprFoto"
                android:layout_marginTop="@dimen/dim_5"
                android:layout_marginLeft="@dimen/dim_90"
                android:id="@+id/txlprDetail"/>
        </RelativeLayout>
        </RelativeLayout>
        <androidx.fragment.app.FragmentContainerView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/fcvLapor"/>
    </LinearLayout>



</FrameLayout>