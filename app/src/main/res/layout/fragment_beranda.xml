<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/white"
    tools:context=".fragmentberanda.BerandaFragment"
    >
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none|vertical">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"

                    android:layout_marginBottom="10dp"
                    >


                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginTop="20dp">
                        <RelativeLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:id="@+id/rlSearchBar"
                            android:layout_centerHorizontal="true">
                        <EditText


                            android:id="@+id/etSearch"
                            android:layout_width="300dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_search"
                            android:hint="Cari informasi, buku &amp; artikel"
                            android:textSize="13sp"
                            android:elegantTextHeight="true"
                            android:textColorHint="#999798"
                            android:inputType="text"
                            android:textColor="@color/black"
                            android:maxLength="50"
                            android:fontFamily="@font/jakartareguler"
                            android:paddingLeft="15sp"
                            android:drawablePadding="15dp"
                            android:drawableStart="@drawable/ic_search" />

                        <ImageButton
                            android:id="@+id/profilUser"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                           android:layout_marginStart="@dimen/dim_12"
                            android:layout_toEndOf="@id/etSearch"
                            android:background="@drawable/bg_profil"
                            android:onClick="profil" />
                    </RelativeLayout>
                    </RelativeLayout>





                </LinearLayout>
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginBottom="24dp"

                    android:layout_marginTop="20dp">
                    <RelativeLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:id="@+id/rlBeranda1"
                        android:layout_centerHorizontal="true">
                        <ImageButton
                            android:layout_marginStart="@dimen/dim_20"
                            android:layout_width="wrap_content"
                            android:layout_height="90dp"
                            android:src="@drawable/ic_kbbi"
                            android:background="@color/transparansi"
                            android:id="@+id/btnKBBI"
                            android:layout_marginBottom="@dimen/dim_20"/>
                        <ImageButton
                            android:layout_marginStart="@dimen/dim_40"
                            android:layout_width="wrap_content"
                            android:layout_height="90dp"
                            android:src="@drawable/ic_kamusbahasa"
                            android:background="@color/transparansi"
                            android:id="@+id/btnKamusBahasa"
                            android:layout_toEndOf="@id/btnKBBI"
                            android:layout_marginBottom="@dimen/dim_20"/>
                        <ImageButton
                            android:layout_marginStart="@dimen/dim_40"
                            android:layout_width="wrap_content"
                            android:layout_height="90dp"
                            android:src="@drawable/ic_databahasa"
                            android:background="@color/transparansi"
                            android:id="@+id/btnDataBahasa"
                            android:layout_toEndOf="@id/btnKamusBahasa"
                            android:layout_marginBottom="@dimen/dim_20"/>
                        <ImageButton
                            android:layout_marginStart="@dimen/dim_40"
                            android:layout_marginEnd="@dimen/dim_20"

                            android:layout_toEndOf="@id/btnDataBahasa"

                            android:layout_width="wrap_content"
                            android:layout_height="90dp"
                            android:src="@drawable/ic_petabahasa"
                            android:background="@color/transparansi"
                            android:id="@+id/btnPetaBahasa"
                            android:layout_marginBottom="@dimen/dim_20"
                            />
                    </RelativeLayout>
                <RelativeLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/rlBeranda2"
                    android:layout_below="@id/rlBeranda1"
                    android:layout_centerHorizontal="true">
                    <ImageButton
                        android:layout_marginStart="@dimen/dim_20"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_vitalitasbahasa"
                        android:background="@color/transparansi"
                        android:id="@+id/btnVitalitasBahasa"

                        />
                    <ImageButton
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/siniar_bahasa"
                        android:background="@color/transparansi"
                        android:id="@+id/btnSiniarBahasa"
                        android:layout_marginStart="@dimen/dim_40"
                        android:layout_toEndOf="@id/btnVitalitasBahasa"
                     />
                    <ImageButton
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_bukubahasadigital"
                        android:background="@color/transparansi"
                        android:id="@+id/btnBukuDigital"
                        android:layout_toEndOf="@id/btnSiniarBahasa"
                        android:layout_marginStart="@dimen/dim_40"
                        />
                    <ImageButton

                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_bahasalainnya"
                        android:background="@color/transparansi"
                        android:id="@+id/btnLainnya"
                        android:layout_toEndOf="@id/btnBukuDigital"
                        android:layout_marginStart="@dimen/dim_40"
                        android:layout_marginEnd="@dimen/dim_20"

                        />
                </RelativeLayout>


                </RelativeLayout>

                <androidx.coordinatorlayout.widget.CoordinatorLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/background_allfitur"
                    android:visibility="gone">

                    <FrameLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/background_rounded"
                        app:layout_behavior="com.google.android.material.bottomappbar.BottomAppBar$Behavior">

                        <include layout="@layout/_ly_beranda_fiturbahasa" />
                    </FrameLayout>
                </androidx.coordinatorlayout.widget.CoordinatorLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:id="@+id/rlBeranda3">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_centerHorizontal="true"
                            android:orientation="vertical"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:paddingBottom="10dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/dim_18"
                        android:text="Ayo, belajar bahasa daerah"
                        android:fontFamily="@font/jakartabold"
                        android:textSize="16sp"
                        android:textColor="@color/black"/>
                    <LinearLayout
                        android:layout_marginStart="@dimen/dim_18"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Pelajari bahasa-bahasa di Indonesia"
                            android:fontFamily="@font/jakartareguler"
                            android:textColor="#999798"
                            android:textSize="13sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lihat Semua"
                            android:fontFamily="@font/jakartabold"
                            android:textColor="@color/primary"
                            android:textSize="13sp"
                            android:layout_marginRight="30dp"
                            android:id="@+id/seeAll1"/>
                    </LinearLayout>


                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none"

                        android:layout_marginTop="12dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingBottom="10dp">
                            <Button
                                android:layout_width="110dp"
                                android:layout_height="34dp"
                                android:elegantTextHeight="true"
                                android:textSize="13sp"
                                android:text="Bahasa daerah"
                                android:textColor="@color/white"
                                android:fontFamily="@font/jakartareguler"
                                android:textAllCaps="false"
                                android:layout_marginStart="@dimen/dim_18"
                                android:background="@drawable/bg_button_ayobelajar"
                                android:id="@+id/btnBahasa1"
                                />
                            <Button
                                android:layout_marginStart="@dimen/dim_18"
                                android:layout_width="110dp"
                                android:layout_height="34dp"
                                android:elegantTextHeight="true"
                                android:textSize="13sp"
                                android:text="Bahasa Buru"
                                android:textColor="@color/black"
                                android:fontFamily="@font/jakartareguler"
                                android:textAllCaps="false"
                                android:background="@drawable/bg_button_ayobelajar_notactivated"
                                android:id="@+id/btnBahasa2"
                                android:layout_marginRight="10dp"/>
                            <Button
                                android:layout_width="110dp"
                                android:layout_height="34dp"
                                android:elegantTextHeight="true"
                                android:textSize="13sp"
                                android:layout_marginStart="@dimen/dim_18"
                                android:text="Bahasa Alune"
                                android:textColor="@color/black"
                                android:fontFamily="@font/jakartareguler"
                                android:textAllCaps="false"
                                android:background="@drawable/bg_button_ayobelajar_notactivated"
                                android:id="@+id/btnBahasa3"
                              />
                            <Button
                                android:layout_width="110dp"
                                android:layout_height="34dp"
                                android:elegantTextHeight="true"
                                android:textSize="13sp"
                                android:layout_marginStart="@dimen/dim_18"
                                android:text="Bahasa Yatoke"
                                android:textColor="@color/black"
                                android:fontFamily="@font/jakartareguler"
                                android:textAllCaps="false"
                                android:background="@drawable/bg_button_ayobelajar_notactivated"
                                android:id="@+id/btnBahasa4"
                                />
                            <Button
                                android:layout_width="110dp"
                                android:layout_height="34dp"
                                android:elegantTextHeight="true"
                                android:textSize="13sp"
                                android:layout_marginStart="@dimen/dim_18"
                                android:text="Bahasa Dalwone"
                                android:textColor="@color/black"
                                android:fontFamily="@font/jakartareguler"
                                android:textAllCaps="false"
                                android:background="@drawable/bg_button_ayobelajar_notactivated"
                                android:id="@+id/btnBahasa5"
                       />

                        </LinearLayout>
                    </HorizontalScrollView>
                </LinearLayout>
                    </RelativeLayout>
                </LinearLayout>
            <androidx.recyclerview.widget.RecyclerView

                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:id="@+id/rvVideoBelajar"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:orientation="vertical"
                    android:layout_height="143dp"
                    android:layout_marginBottom="10dp"
                    >
                    <TextView
                        android:layout_marginStart="@dimen/dim_12"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Berita kebahasaan hari ini"
                        android:fontFamily="@font/jakartabold"
                        android:textSize="16sp"
                        android:textColor="@color/black"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp"
                        android:layout_marginStart="@dimen/dim_12">
                        <!--        nanti tambahkan tag html legacy di kotlinnya-->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Baca update berita terkait dengan kebahasaan "
                            android:fontFamily="@font/jakartareguler"
                            android:textColor="#999798"

                            android:textSize="13sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lihat Semua"
                            android:fontFamily="@font/jakartabold"
                            android:textColor="@color/primary"
                            android:textSize="13sp"
                            android:layout_marginRight="15dp"
                            android:id="@+id/seeAll2"/>
                    </LinearLayout>
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none"
                        android:layout_marginTop="25dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <Button
                                android:layout_marginStart="@dimen/dim_12"
                                android:layout_width="110dp"
                                android:layout_height="34dp"
                                android:elegantTextHeight="true"
                                android:textSize="13sp"
                                android:text="Terbaru"
                                android:textColor="@color/white"
                                android:fontFamily="@font/jakartareguler"
                                android:textAllCaps="false"
                                android:background="@drawable/bg_button_ayobelajar"
                                android:id="@+id/btnBerita1"
                                />
                            <Button
                                android:layout_marginStart="@dimen/dim_18"
                                android:layout_width="110dp"
                                android:layout_height="34dp"
                                android:elegantTextHeight="true"
                                android:textSize="13sp"
                                android:text="Balai Bahasa"
                                android:textColor="@color/black"
                                android:fontFamily="@font/jakartareguler"
                                android:textAllCaps="false"
                                android:background="@drawable/bg_button_ayobelajar_notactivated"
                                android:id="@+id/btnBerita2"
                                />
                            <Button
                                android:layout_width="110dp"
                                android:layout_marginStart="@dimen/dim_18"
                                android:layout_height="34dp"
                                android:elegantTextHeight="true"
                                android:textSize="13sp"
                                android:text="Kantor Bahasa"
                                android:textColor="@color/black"
                                android:fontFamily="@font/jakartareguler"
                                android:textAllCaps="false"
                                android:background="@drawable/bg_button_ayobelajar_notactivated"
                                android:id="@+id/btnBerita3"
                                />
                            <Button
                                android:layout_width="110dp"
                                android:layout_height="34dp"
                                android:elegantTextHeight="true"
                                android:textSize="13sp"
                                android:text="Badan Bahasa"
                                android:textColor="@color/black"
                                android:fontFamily="@font/jakartareguler"
                                android:textAllCaps="false"
                                android:layout_marginStart="@dimen/dim_18"
                                android:background="@drawable/bg_button_ayobelajar_notactivated"
                                android:id="@+id/btnBerita4"
                             />
                            <Button
                                android:layout_width="110dp"
                                android:layout_height="34dp"
                                android:elegantTextHeight="true"
                                android:layout_marginStart="@dimen/dim_18"
                                android:textSize="13sp"
                                android:text="Merdeka Belajar"
                                android:textColor="@color/black"
                                android:fontFamily="@font/jakartareguler"
                                android:textAllCaps="false"
                                android:background="@drawable/bg_button_ayobelajar_notactivated"
                                android:id="@+id/btnBerita5"
                                />

                        </LinearLayout>
                    </HorizontalScrollView>
                </LinearLayout>
                <androidx.recyclerview.widget.RecyclerView
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:id="@+id/rvBerita"
                    android:layout_marginBottom="50dp"/>



            </LinearLayout>


        </androidx.core.widget.NestedScrollView>


</RelativeLayout>

</FrameLayout>