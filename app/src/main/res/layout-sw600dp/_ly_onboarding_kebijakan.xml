<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="@dimen/dim_350"
    android:orientation="vertical"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/dim_80"
    android:layout_marginHorizontal="@dimen/dim_40"
    >
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:text="Dengan masuk atau mendaftar, kamu menyetujui"
        android:fontFamily="@font/jakartalight"
        android:textSize="13.1sp"/>
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="-5dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Terms of Service"
            android:textColor="@color/white"

            android:fontFamily="@font/jakartabolditalic"
            android:id="@+id/btnKetentuan"
            android:onClick="layanan"/>
        <TextView
            android:textColor="@color/white"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="dan"
            android:fontFamily="@font/jakartareguler"
            android:paddingLeft="@dimen/dim_3"
            android:paddingRight="@dimen/dim_3"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/btnPrivasi"
            android:text="Privacy Policy"
            android:textColor="@color/white"
            android:fontFamily="@font/jakartabolditalic"
            android:onClick="privasi"
            />

    </LinearLayout>
    

</LinearLayout>