<?xml version="1.0" encoding="utf-8"?>
<!--bg_tabkbbiactivated-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background color -->
    <item android:drawable="@android:color/transparent" />

    <!-- Bottom border line -->
    <item
        android:top="-5dp"
        android:left="-5dp"
        android:right="-5dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/transparansi" /> <!-- Set your background color here -->
            <stroke
                android:width="4dp"
            android:color="@color/biru" /> <!-- Set your underline color here -->
        </shape>
    </item>
</layer-list>

